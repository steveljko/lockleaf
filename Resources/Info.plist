<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Lockleaf</string>
    <key>CFBundleDisplayName</key>
    <string>Lockleaf</string>
    <key>CFBundleIdentifier</key>
    <string>app.lockleaf.mac</string>
    <key>CFBundleExecutable</key>
    <string>Lockleaf</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>NSHumanReadableCopyright</key>
    <string>No analytics. No telemetry. Your secrets stay on this Mac.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Shown in the native biometric prompt. Touch ID on Mac surfaces this. -->
    <key>NSFaceIDUsageDescription</key>
    <string>Unlock your Lockleaf vault with biometrics.</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
    <!-- Registers the app's iCloud Drive container so encrypted backups appear
         under the app's name in the user's iCloud Drive. -->
    <key>NSUbiquitousContainers</key>
    <dict>
        <key>iCloud.app.lockleaf.mac</key>
        <dict>
            <key>NSUbiquitousContainerIsDocumentScopePublic</key>
            <true/>
            <key>NSUbiquitousContainerName</key>
            <string>Lockleaf</string>
            <key>NSUbiquitousContainerSupportedFolderLevels</key>
            <string>One</string>
        </dict>
    </dict>
</dict>
</plist>
